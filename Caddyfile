(security_headers) {
    header {
        # 'defer' = Header werden NACH dem Backend gesetzt, ueberschreiben
        # also auch das was uvicorn an Headers liefert. Ohne 'defer' kann
        # reverse_proxy die Header verlieren.
        defer
        # HSTS: erzwingt HTTPS fuer 1 Jahr inkl. Subdomains. Verhindert
        # Downgrade-Attacks. preload optional (manueller submit-Schritt).
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Verhindert MIME-Sniffing → Browser ignoriert content-type-Guess
        X-Content-Type-Options "nosniff"
        # Verhindert dass die Seite in iframe geladen wird (Clickjacking)
        X-Frame-Options "DENY"
        # Browser sendet Referrer nur an gleiche Origin → kein PII-Leak
        # via Outbound-Links
        Referrer-Policy "strict-origin-when-cross-origin"
        # Cross-Origin-Opener-Policy: isoliert Browsing-Context
        Cross-Origin-Opener-Policy "same-origin"
        # Permissions-Policy: keine sensiblen APIs ohne expliziten Bedarf
        Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
        # Phase B8: CSP — verhindert XSS und drittpartei-Script-Injection.
        # 'unsafe-inline' fuer scripts ist noetig fuer die Admin-Chart-
        # Bloecke; fuer Style ebenfalls weil Anfrage-Formular generierte
        # inline-Styles nutzt. Frame-ancestors 'none' ist Belt-and-
        # Suspenders zu X-Frame-Options. img-src + connect-src bewusst
        # eng gefasst.
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
        # Server-Header verstecken (verhindert Versions-Disclosure)
        -Server
    }
}

gewerbeagent.de {
    encode gzip

    import security_headers

    reverse_proxy framework:8001 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format console
    }
}

www.gewerbeagent.de {
    encode gzip

    import security_headers

    root * /srv/website
    file_server

    log {
        output file /var/log/caddy/website-access.log {
            roll_size 10mb
            roll_keep 5
        }
        format console
    }
}

# =====================================================================
# Phase B6: oeffentliche Status-Page (status.gewerbeagent.de)
# =====================================================================
# Aktivierung:
#   1. DNS A-Record fuer status.gewerbeagent.de auf Server-IP zeigen
#   2. caddy reload — Caddy holt automatisch ein Let's-Encrypt-Cert
# Block proxied alles ans Framework, das nur die Status-Routes
# beantwortet. Andere Endpoints (Webhook, /admin) bleiben auch hier
# erreichbar — Caddy filtert nicht nach Path, das ist akzeptabel weil
# alles ohne /admin-Auth eh limitiert ist. Cleaner waere ein Rewrite,
# bringt aber kaum Sicherheitsgewinn.
status.gewerbeagent.de {
    encode gzip
    import security_headers

    # Default: zur Status-Page weiterleiten wenn nicht /api/status oder
    # /status direkt angefragt wird.
    @not_status {
        not path /status /api/status
    }
    redir @not_status /status 302

    reverse_proxy framework:8001 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    log {
        output file /var/log/caddy/status-access.log {
            roll_size 10mb
            roll_keep 3
        }
        format console
    }
}

# =====================================================================
# Dev-Stack: dev.gewerbeagent.de
# =====================================================================
# AKTIVIERUNG erst nachdem (siehe INFRA-MANUAL-STEPS.md):
#   1. DNS A-Record fuer dev.gewerbeagent.de auf Server-IP zeigt
#   2. Dev-Framework-Container laeuft (gewerbeagent_framework_dev)
#   3. basicauth-Hash unten gegen echten Wert ersetzt
# Dann: docker compose -p prod restart caddy (laed Caddyfile neu)
#
# Vor Aktivierung bleibt der Block auskommentiert. Caddy ignoriert
# die Lines mit '#' — keinerlei Wirkung auf Prod.
#
# basicauth-Hash erzeugen:
#   docker exec gewerbeagent_caddy caddy hash-password --plaintext "<dein-passwort>"
#
