# Template fuer .env.dev (Dev-Stack)
# Kopiere diese Datei zu /opt/gewerbeagent/framework-dev/.env.dev und
# ersetze alle <PLATZHALTER>.

# --- Umgebung ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# --- Datenbank (DEV-DB!) ---
# Gleicher Postgres-Container wie Prod, aber andere Datenbank.
# DB 'gewerbeagent_dev' muss vorher angelegt sein (siehe
# scripts/init-databases.sh oder INFRA-MANUAL-STEPS.md).
DATABASE_URL=postgresql+asyncpg://gewerbeagent:<POSTGRES_PASSWORD>@postgres:5432/gewerbeagent_dev
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>

# --- Security ---
# Eigene Keys fuer Dev! Nicht von Prod kopieren — sonst koennen Tokens
# zwischen den Stacks ausgetauscht werden (Privacy-Bug).
SECRET_KEY=<DEV_SECRET_KEY>
ENCRYPTION_KEY=<DEV_ENCRYPTION_KEY>

# --- Google / Gemini ---
# Gleicher Vertex-Key OK (oder eigener Dev-GCP-Project fuer Quoten-Trennung)
GOOGLE_APPLICATION_CREDENTIALS=/app/vertex-key.json
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LOCATION=europe-west3

# --- ElevenLabs (eigener Dev-Account empfohlen wegen Quoten) ---
ELEVENLABS_API_KEY=

# --- Admin-Telegram-Bot (Alerts an Sven, gleich wie Prod ist OK) ---
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# --- Public URL (DEV!) ---
PUBLIC_URL=https://dev.gewerbeagent.de

# --- Cron-Jobs in Dev abschalten ---
# Wenn 'true', werden Background-Loops (Mail-Polling, Payment-Monitor,
# Summary-Push, DSGVO-Cleanup) NICHT gestartet. Verhindert dass Dev-
# Stack echte API-Quoten verbraucht oder Demo-Mails verschickt.
DEV_CRON_DISABLED=true

# --- Webhook-Secrets — eigene Werte fuer Dev! ---
TELEGRAM_WEBHOOK_SECRET=<DEV_TELEGRAM_SECRET>
BREVO_WEBHOOK_SECRET=<DEV_BREVO_SECRET>
ELEVENLABS_WEBHOOK_SECRET=<DEV_ELEVENLABS_SECRET>
