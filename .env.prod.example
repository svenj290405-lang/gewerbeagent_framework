# Template fuer .env (Prod-Stack)
# Kopiere diese Datei zu .env und ersetze alle <PLATZHALTER>.
# Aktuelle Prod-.env ist bereits konfiguriert — diese Vorlage dient
# nur als Referenz fuer neue Server-Setups.

# --- Umgebung ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# --- Datenbank (Prod-DB) ---
DATABASE_URL=postgresql+asyncpg://gewerbeagent:<POSTGRES_PASSWORD>@postgres:5432/gewerbeagent
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>

# --- Security (empfohlen: 64+ Zeichen, generiere via `openssl rand -base64 48`) ---
# Bestehende 32-byte-Keys (~43 Zeichen) starten weiterhin durch (nur
# Boot-Warning). Bei Neu-Setups bitte direkt 48 Bytes nehmen.
SECRET_KEY=<SECRET_KEY>
ENCRYPTION_KEY=<ENCRYPTION_KEY>

# --- Google / Gemini ---
GOOGLE_APPLICATION_CREDENTIALS=/app/vertex-key.json
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LOCATION=europe-west3

# --- ElevenLabs ---
ELEVENLABS_API_KEY=

# --- OpenRouteService (optional, fuer Smart-Termine mit Fahrtzeit) ---
# Free-Tier: 2.000 Requests/Tag. Ohne Key faellt Smart-Routing sauber zurueck.
OPENROUTESERVICE_API_KEY=

# --- Admin-Telegram-Bot (Alerts an Sven) ---
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# --- Public URL (PROD!) ---
PUBLIC_URL=https://gewerbeagent.de

# Webhook-Signature-Secrets — pro Provider eindeutig.
TELEGRAM_WEBHOOK_SECRET=<TELEGRAM_SECRET>
BREVO_WEBHOOK_SECRET=<BREVO_SECRET>
ELEVENLABS_WEBHOOK_SECRET=<ELEVENLABS_SECRET>
