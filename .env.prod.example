# Template fuer .env (Prod-Stack)
# Kopiere diese Datei zu .env und ersetze alle <PLATZHALTER>.
# Aktuelle Prod-.env ist bereits konfiguriert — diese Vorlage dient
# nur als Referenz fuer neue Server-Setups.

# --- Umgebung ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# --- Datenbank (Prod-DB) ---
DATABASE_URL=postgresql+asyncpg://gewerbeagent:<POSTGRES_PASSWORD>@postgres:5432/gewerbeagent
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>

# --- Security (empfohlen: 64+ Zeichen, generiere via `openssl rand -base64 48`) ---
# Bestehende 32-byte-Keys (~43 Zeichen) starten weiterhin durch (nur
# Boot-Warning). Bei Neu-Setups bitte direkt 48 Bytes nehmen.
SECRET_KEY=<SECRET_KEY>
ENCRYPTION_KEY=<ENCRYPTION_KEY>

# --- Google / Gemini ---
GOOGLE_APPLICATION_CREDENTIALS=/app/vertex-key.json
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LOCATION=europe-west3

# --- ElevenLabs ---
ELEVENLABS_API_KEY=

# --- Google Maps Platform (bevorzugt, fuer Smart-Termine mit Fahrtzeit) ---
# Free-Tier: $200/Monat Google-Credit = ca. 40k Geocodes + 40k Distance-
# Matrix-Eintraege/Monat. Reicht fuer Dutzende Tenants problemlos.
#
# Setup (3 Klicks im selben GCP-Projekt wie Vertex AI):
#   1. console.cloud.google.com/apis/library
#      → "Geocoding API" suchen → "Aktivieren"
#      → "Distance Matrix API" suchen → "Aktivieren"
#   2. console.cloud.google.com/apis/credentials
#      → "Anmeldedaten erstellen" → "API-Schluessel"
#   3. Bei dem neuen Key auf "Bearbeiten" → "API-Einschraenkungen"
#      → nur Geocoding + Distance Matrix anhaken → Speichern.
#   4. Den Key unten eintragen.
#
# Ohne Key: Werkstatt-Adresse wird trotzdem gespeichert,
# Fahrtzeit-Optimierung pausiert (Termine werden ohne Distanz vergeben).
GOOGLE_MAPS_API_KEY=

# --- OpenRouteService (Fallback wenn kein Google-Maps-Key) ---
# Free-Tier: 2.000 Requests/Tag, EU-hosted (Heidelberg). Nur noetig wenn
# du KEIN GCP-Projekt nutzen willst — sonst Maps bevorzugen.
OPENROUTESERVICE_API_KEY=

# --- Admin-Telegram-Bot (Alerts an Sven) ---
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# --- Public URL (PROD!) ---
PUBLIC_URL=https://gewerbeagent.de

# Webhook-Signature-Secrets — pro Provider eindeutig.
TELEGRAM_WEBHOOK_SECRET=<TELEGRAM_SECRET>
BREVO_WEBHOOK_SECRET=<BREVO_SECRET>
ELEVENLABS_WEBHOOK_SECRET=<ELEVENLABS_SECRET>

# --- Sentry / Error-Tracking (Phase B2, optional) ---
# Aktivierung: sentry-sdk[fastapi] in pyproject.toml + Image-Rebuild,
# dann SENTRY_DSN setzen. Ohne DSN: silent skipped, kein Boot-Fail.
# Self-Hosted via GlitchTip: einfach den GlitchTip-DSN hier eintragen.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0
# GIT_COMMIT_SHA wird von deploy_prod.sh automatisch gesetzt — nicht
# manuell setzen.

# --- Inhaber-/Mitarbeiter-PWA (loest den Telegram-Bot ab) ---
# Basis-URL der App (Magic-Link-Mails + Service-Worker-Scope).
APP_BASE_URL=https://app.gewerbeagent.de
# Web-Push (VAPID) — Schluesselpaar erzeugen via:
#   python -m core.integrations.push_notifier --genkey
# Leer = Push deaktiviert (App laeuft, schickt nur keine Benachrichtigungen).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:datenschutz@gewerbeagent.de
